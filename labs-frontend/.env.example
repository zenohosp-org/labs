# ══════════════════════════════════════════════════════════
#  Labs Frontend — Environment Variables
#  Copy this file to .env.local and fill in the values.
#  .env.local is gitignored — NEVER commit a real token.
# ══════════════════════════════════════════════════════════

# Backend URL — local dev points to the labs-backend on 8086
VITE_API_BASE_URL=http://localhost:8086

# ── Dev mock auth (bypasses SSO for local development) ────────────────────
# Get a real signed JWT from the project lead (or mint one with the shared
# jwt.secret). Backend's JwtFilter validates it via the Authorization: Bearer
# header injected by labsClient.js when VITE_DEV_MOCK_AUTH=true.
VITE_DEV_MOCK_AUTH=true
VITE_MOCK_USER_ID=
VITE_MOCK_USER_EMAIL=
VITE_MOCK_USER_ROLE=hospital_admin
VITE_MOCK_HOSPITAL_ID=
VITE_MOCK_JWT=
